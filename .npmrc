# Hoist TypeScript publicly so Angular compiler-cli + ng-packagr + vue-tsc
# all see the *same* TS instance. Without this, pnpm can land different TS
# versions in different transitive trees, and Angular's `@angular/compiler-cli`
# crashes with `Debug Failure` mid-transform because the AST nodes from
# typescript@5.6 and typescript@5.9 don't share the same prototype chain.
public-hoist-pattern[]=typescript
public-hoist-pattern[]=@types/*

# Be tolerant with peer-dep mismatches across workspaces (Angular 21 wants
# typescript@>=5.9 ; vue-tsc 21 accepts 5.6+ ; aligning everyone on 5.9 is
# safest but pnpm should not error if a sub-dep declares a narrower range).
auto-install-peers=true
strict-peer-dependencies=false
