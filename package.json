{
  "name": "mrxgrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently --kill-others-on-fail -n app,storybook -c blue,magenta \"npm run dev\" \"npm run storybook\"",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:app": "vue-tsc --build && vite build",
    "build:all": "VITE_BASE=/mrxgrid/mrxgrid-app/ npm run build:app && STORYBOOK_BASE_PATH=/mrxgrid/ npm run build-storybook",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@mozaic-ds/icons-vue": "^2.6.0",
    "@mozaic-ds/styles": "2.23.1",
    "@mozaic-ds/tokens": "2.23.1",
    "@mozaic-ds/vue": "^2.19.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/vue3-vite": "^10.4.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "^1.6.19",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.67.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-vue": "~10.9.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.1",
    "oxlint": "~1.67.0",
    "prettier": "3.8.3",
    "sass-embedded": "^1.100.0",
    "storybook": "^10.4.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
